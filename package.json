{
  "name": "clausona",
  "version": "0.1.0",
  "private": true,
  "description": "Ink-based rewrite of clausona",
  "type": "module",
  "bin": {
    "clausona": "dist/index.js"
  },
  "scripts": {
    "build": "rm -rf dist && node build.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@inkjs/ui": "2.0.0",
    "chalk": "^5.6.2",
    "ink": "6.8.0",
    "ink-text-input": "6.0.0",
    "react": "19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "20.12.7",
    "@types/react": "19.2.2",
    "@types/react-test-renderer": "19.1.0",
    "esbuild": "0.27.3",
    "ink-testing-library": "4.0.0",
    "react-devtools-core": "7.0.1",
    "react-test-renderer": "19.2.4",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
